{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "employee"] },
        "avatar": { "type": "string" },
        "departmentId": { "type": "string" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "An item in the inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "status": { "type": "string", "enum": ["In Stock", "Low Stock", "Out of Stock"] },
        "lastUpdated": { "type": "string" }
      },
      "required": ["id", "sku", "name", "category", "quantity", "status", "lastUpdated"]
    },
    "Department": {
      "title": "Department",
      "description": "A department in the company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "headId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Employee": {
      "title": "Employee",
      "description": "An employee in the company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "departmentId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "employee"] },
        "position": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Terminated"] },
        "joinDate": { "type": "string" }
      },
      "required": ["id", "name", "email", "departmentId", "role", "position", "status", "joinDate"]
    },
    "Task": {
      "title": "Task",
      "description": "A task assigned to an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "assigneeId": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] },
        "dueDate": { "type": "string" }
      },
      "required": ["id", "title", "assigneeId", "status", "dueDate"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "An audit log entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "module": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["id", "timestamp", "userId", "userName", "action", "module", "details"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "status": { "type": "string", "enum": ["Completed", "Pending", "Failed"] }
      },
      "required": ["id", "date", "description", "amount", "type", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles for authentication."
    },
    "/inventory/{itemId}": {
      "schema": { "$ref": "#/entities/InventoryItem" },
      "description": "Inventory items."
    },
    "/departments/{departmentId}": {
      "schema": { "$ref": "#/entities/Department" },
      "description": "Company departments."
    },
    "/employees/{employeeId}": {
      "schema": { "$ref": "#/entities/Employee" },
      "description": "Employee records."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Assigned tasks."
    },
    "/audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "System audit logs."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Financial transactions."
    }
  }
}
